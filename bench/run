#!/usr/bin/env bash
# bench/run — benchmark hdi against static READMEs and report timings.
#
# Usage:
#   ./bench/run              # run benchmarks, print results only
#   ./bench/run --log        # also save to bench/results.csv (used by release)
#   ./bench/run --compare    # compare current results against last logged release

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
HDI="$ROOT_DIR/hdi"
LOG="$SCRIPT_DIR/results.csv"
RUNS=5  # iterations per fixture for stable median

# ── Helpers ──────────────────────────────────────────────────────────────────

median() {
  sort -n | awk '{a[NR]=$1} END {print a[int((NR+1)/2)]}'
}

if [[ "$(uname)" == "Darwin" ]]; then
  time_ms() {
    local start end
    start=$(/usr/bin/perl -MTime::HiRes=time -e 'printf "%.6f\n", time')
    "$@" >/dev/null 2>&1
    end=$(/usr/bin/perl -MTime::HiRes=time -e 'printf "%.6f\n", time')
    /usr/bin/perl -e "printf \"%.1f\n\", ($end - $start) * 1000"
  }
else
  time_ms() {
    local start end
    start=$(date +%s%N)
    "$@" >/dev/null 2>&1
    end=$(date +%s%N)
    echo "$(( (end - start) / 1000000 )).$(( (end - start) / 100000 % 10 ))"
  }
fi

# ── Version and machine info ──────────────────────────────────────────────────

version=$(grep -m1 '^VERSION=' "$HDI" | sed 's/VERSION="//;s/"//')
timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Build a short machine identifier: Brand_Model_Cores
if [[ "$(uname)" == "Darwin" ]]; then
  chip=$(sysctl -n machdep.cpu.brand_string 2>/dev/null | sed 's/ /_/g')
  cores=$(sysctl -n hw.ncpu 2>/dev/null)
else
  chip=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | sed 's/.*: //;s/ /_/g')
  cores=$(nproc 2>/dev/null)
fi
machine="${chip:-unknown}_${cores:-?}c"

# ── Benchmark ────────────────────────────────────────────────────────────────

declare -a names=()
declare -a lines=()
declare -a medians=()

for readme in "$SCRIPT_DIR"/small.md "$SCRIPT_DIR"/medium.md "$SCRIPT_DIR"/large.md "$SCRIPT_DIR"/stress.md; do
  [[ -f "$readme" ]] || continue
  name=$(basename "$readme" .md)
  linecount=$(wc -l < "$readme" | tr -d ' ')

  # Warm-up run (prime disk cache)
  "$HDI" all --ni "$readme" >/dev/null 2>&1 || true

  timings=""
  for (( i=0; i<RUNS; i++ )); do
    ms=$(time_ms "$HDI" all --ni "$readme")
    timings+="$ms"$'\n'
  done

  med=$(echo "$timings" | grep -v '^$' | median)

  names+=("$name")
  lines+=("$linecount")
  medians+=("$med")
done

# ── Parse flags ──────────────────────────────────────────────────────────────

DO_LOG=false
DO_COMPARE=false
for flag in "$@"; do
  case "$flag" in
    --log)     DO_LOG=true ;;
    --compare) DO_COMPARE=true ;;
  esac
done

# ── Print results ────────────────────────────────────────────────────────────

printf "\n"
printf "  hdi %s on %s\n" "$version" "$machine"
printf "  %s — %d runs per fixture\n\n" "$timestamp" "$RUNS"

if $DO_COMPARE && [[ -f "$LOG" ]]; then
  # Find the latest logged version
  prev_version=$(awk -F, 'NR>1 {print $2}' "$LOG" | sort -t. -k1,1n -k2,2n -k3,3n | tail -1)

  if [[ -n "$prev_version" ]]; then
    printf "  %-12s %6s %10s %10s %8s\n" "Fixture" "Lines" "Current" "v$prev_version" "Δ"
    printf "  ────────────────────────────────────────────────────\n"
    for i in "${!names[@]}"; do
      fixture="${names[$i]}"
      cur="${medians[$i]}"
      prev=$(awk -F, -v ver="$prev_version" -v fix="$fixture" '$2==ver && $4==fix {print $6}' "$LOG")
      if [[ -n "$prev" ]]; then
        delta=$(/usr/bin/perl -e "printf '%+.1f%%', (($cur - $prev) / $prev) * 100")
        printf "  %-12s %6s %8sms %8sms %8s\n" "$fixture" "${lines[$i]}" "$cur" "$prev" "$delta"
      else
        printf "  %-12s %6s %8sms %8s- %8s\n" "$fixture" "${lines[$i]}" "$cur" "" "-"
      fi
    done
  else
    printf "  %-12s %6s %9s\n" "Fixture" "Lines" "Median"
    printf "  ──────────────────────────────\n"
    for i in "${!names[@]}"; do
      printf "  %-12s %6s %7sms\n" "${names[$i]}" "${lines[$i]}" "${medians[$i]}"
    done
  fi
else
  printf "  %-12s %6s %9s\n" "Fixture" "Lines" "Median"
  printf "  ──────────────────────────────\n"
  for i in "${!names[@]}"; do
    printf "  %-12s %6s %7sms\n" "${names[$i]}" "${lines[$i]}" "${medians[$i]}"
  done
fi
printf "\n"

# ── Log to CSV ───────────────────────────────────────────────────────────────

if ! $DO_LOG; then
  exit 0
fi

if [[ ! -f "$LOG" ]]; then
  echo "timestamp,version,machine,fixture,lines,median_ms" > "$LOG"
fi

# Remove any existing rows for this version (keep header + other versions)
tmpfile=$(mktemp)
awk -F, -v ver="$version" 'NR==1 || $2 != ver' "$LOG" > "$tmpfile"
mv "$tmpfile" "$LOG"

# Append new rows
for i in "${!names[@]}"; do
  echo "$timestamp,$version,$machine,${names[$i]},${lines[$i]},${medians[$i]}" >> "$LOG"
done

printf "  Logged to bench/results.csv\n\n"
